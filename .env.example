# App runtime
APP_ENV=development
APP_DEBUG=false
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5500

# SQLite path relative to repo root
DATABASE_URL=db/database.db

# JSON array of allowed browser origins for local frontend servers
CORS_ORIGINS=["http://127.0.0.1:5500","http://localhost:5500","http://127.0.0.1:8080","http://localhost:8080"]
